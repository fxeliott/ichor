# Cloudflare account, R2 bucket, Tunnel credentials
# - Account ID: dash.cloudflare.com → top-right account selector → ID
# - R2 access keys: R2 → Manage R2 API Tokens → Create API token (read+write on ichor-walg-eu)
# - Tunnel credentials: cloudflared tunnel create + cloudflared tunnel token <UUID>

CLOUDFLARE_ACCOUNT_ID=REPLACE
CLOUDFLARE_API_TOKEN=REPLACE  # for cloudflared + zero-trust APIs

# R2 (S3-compatible) — wired into wal-g via group_vars
R2_ACCOUNT_ID=REPLACE
R2_ACCESS_KEY_ID=REPLACE
R2_SECRET_ACCESS_KEY=REPLACE
R2_BUCKET=ichor-walg-eu
R2_ENDPOINT=https://REPLACE.eu.r2.cloudflarestorage.com  # EU jurisdiction

# Cloudflare Tunnel (Hetzner outbound)
CLOUDFLARED_TUNNEL_UUID=REPLACE  # set after `cloudflared tunnel create ichor-hetzner-out`
CLOUDFLARED_TUNNEL_TOKEN=REPLACE
