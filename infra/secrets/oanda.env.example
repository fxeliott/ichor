# OANDA Practice account (free, used as primary FX/metals/indices feed)
# https://developer.oanda.com/ → Practice → Generate API token
# 20 streams max, 2 connections/s (per AUDIT_V3 §7)

OANDA_API_TOKEN=REPLACE
OANDA_ACCOUNT_ID=REPLACE  # format: 101-XXX-XXXXXXX-001
OANDA_ENV=practice  # never set to "live" without explicit Phase 7+ decision
OANDA_STREAM_HOST=stream-fxpractice.oanda.com
OANDA_API_HOST=api-fxpractice.oanda.com
