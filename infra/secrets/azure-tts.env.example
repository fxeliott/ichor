# Azure Speech (Cognitive Services) — Neural TTS FR free tier (5M chars/month)
# https://portal.azure.com → Create resource → Speech → free tier F0
# Voice: fr-FR-DeniseNeural (default) or fr-FR-HenriNeural (A/B test Phase 0 W4)

AZURE_SPEECH_KEY=REPLACE
AZURE_SPEECH_REGION=westeurope  # closest to France for low latency
AZURE_SPEECH_VOICE_DEFAULT=fr-FR-DeniseNeural
AZURE_SPEECH_VOICE_BACKUP=fr-FR-HenriNeural
