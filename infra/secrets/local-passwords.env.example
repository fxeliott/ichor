# Local passwords for self-hosted services (no third party)
# Generate with: openssl rand -base64 32  (or `pwgen 32 1` if installed)
# Each password used ONCE for ONE service.

LANGFUSE_POSTGRES_PASSWORD=REPLACE_32_BYTES_RANDOM
LANGFUSE_MINIO_PASSWORD=REPLACE_32_BYTES_RANDOM
N8N_POSTGRES_PASSWORD=REPLACE_32_BYTES_RANDOM
GRAFANA_ADMIN_PASSWORD=REPLACE_32_BYTES_RANDOM
LANGFUSE_NEXTAUTH_SECRET=REPLACE_32_BYTES_RANDOM
LANGFUSE_SALT=REPLACE_32_BYTES_RANDOM
LANGFUSE_ENCRYPTION_KEY=REPLACE_64_HEX_CHARS  # openssl rand -hex 32
