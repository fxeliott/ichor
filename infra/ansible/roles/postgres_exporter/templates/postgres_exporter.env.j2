# postgres_exporter env — managed by Ansible. Do not edit by hand.
# Loaded by /etc/systemd/system/postgres_exporter.service
DATA_SOURCE_NAME=postgresql://{{ postgres_exporter_db_user }}:{{ postgres_exporter_db_password }}@127.0.0.1:5432/{{ postgres_exporter_db_name }}?sslmode=disable
PG_EXPORTER_WEB_LISTEN_ADDRESS=:{{ postgres_exporter_port | default(9187) }}
PG_EXPORTER_EXTEND_QUERY_PATH=/etc/postgres_exporter/queries.yml
PG_EXPORTER_AUTO_DISCOVER_DATABASES=false
