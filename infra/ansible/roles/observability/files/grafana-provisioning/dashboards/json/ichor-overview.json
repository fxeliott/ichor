{
  "title": "Ichor — Overview",
  "uid": "ichor-overview",
  "tags": ["ichor", "phase-0", "operational"],
  "timezone": "Europe/Paris",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Briefings completed (24h)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 4 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT now() AS time, count(*) AS value FROM briefings WHERE status = 'completed' AND triggered_at > now() - interval '24 hours'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Briefings failed (24h)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT now() AS time, count(*) AS value FROM briefings WHERE status = 'failed' AND triggered_at > now() - interval '24 hours'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active alerts (unack)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT now() AS time, count(*) AS value FROM alerts WHERE acknowledged_at IS NULL",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Critical alerts (unack)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT now() AS time, count(*) AS value FROM alerts WHERE acknowledged_at IS NULL AND severity = 'critical'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Briefing duration p50/p95 (Claude subprocess, 7d)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', triggered_at) AS time, percentile_disc(0.5) WITHIN GROUP (ORDER BY claude_duration_ms) AS \"p50\", percentile_disc(0.95) WITHIN GROUP (ORDER BY claude_duration_ms) AS \"p95\" FROM briefings WHERE status = 'completed' AND claude_duration_ms IS NOT NULL AND triggered_at > now() - interval '7 days' GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Alerts by severity (rolling 30 min, 24h)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT time_bucket('30 min', triggered_at) AS time, severity AS metric, count(*) AS value FROM alerts WHERE triggered_at > now() - interval '24 hours' GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "table",
      "title": "Latest 10 briefings",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": { "showHeader": true },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT triggered_at AS \"When\", briefing_type AS \"Type\", status AS \"Status\", claude_duration_ms AS \"Duration ms\", length(briefing_markdown) AS \"MD chars\", array_to_string(assets, ', ') AS \"Assets\" FROM briefings ORDER BY triggered_at DESC LIMIT 10",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Bias signal mean P(long) per asset (24h)",
      "datasource": { "type": "postgres", "uid": "Postgres-Ichor" },
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT time_bucket('30 min', generated_at) AS time, asset AS metric, avg(CASE WHEN direction = 'short' THEN 1 - probability ELSE probability END) AS value FROM bias_signals WHERE horizon_hours = 24 AND generated_at > now() - interval '24 hours' GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    }
  ]
}
