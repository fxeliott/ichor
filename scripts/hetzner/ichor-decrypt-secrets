#!/usr/bin/env bash
# ichor-decrypt-secrets — SOPS+age decryption of infra/secrets/*.env into RAM.
#
# Invoked as systemd ExecStartPre on briefing services (cf register-cron-briefings.sh).
# Reads SOPS-encrypted *.env files from /opt/ichor/infra/secrets/ and concatenates
# the decrypted KEY=VALUE pairs into /dev/shm/ichor-secrets.env (tmpfs, never on disk).
#
# Caller MUST shred the output file in ExecStartPost; this script only writes it.
#
# Required:
#   - sops binary on PATH (apt: sops)
#   - SOPS_AGE_KEY_FILE env var pointing at the age private key (root-readable, 0400)
#
# Behavior:
#   - Skips files that are NOT SOPS-encrypted (no `sops:` top-level key)
#   - Skips *.example files
#   - Fails fast on any decryption error
#   - Writes UTF-8, no BOM
#
# Exit codes: 0 OK · 1 missing dep · 2 missing key · 3 decrypt failure · 4 IO failure

set -euo pipefail

readonly OUT_FILE="${ICHOR_SECRETS_OUT:-/dev/shm/ichor-secrets.env}"
readonly SECRETS_DIR="${ICHOR_SECRETS_DIR:-/opt/ichor/infra/secrets}"
readonly LOCK_FILE="/var/lock/ichor-decrypt-secrets.lock"

log() { printf '[%s] %s\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')" "$*" >&2; }
# fail "<message>" <exit-code>
fail() { log "FATAL: $1"; exit "$2"; }

command -v sops >/dev/null 2>&1 || fail "sops binary not found on PATH" 1
[ -n "${SOPS_AGE_KEY_FILE:-}" ] || fail "SOPS_AGE_KEY_FILE not set" 2
[ -r "${SOPS_AGE_KEY_FILE}" ] || fail "SOPS_AGE_KEY_FILE not readable: ${SOPS_AGE_KEY_FILE}" 2
[ -d "${SECRETS_DIR}" ] || fail "secrets dir not found: ${SECRETS_DIR}" 4

# Single-flight: prevent two ExecStartPre racing on the same tmpfs target.
# 30s timeout — fail fast if a previous instance is stuck (don't wait the
# 90s default systemd TimeoutStartSec).
exec 9>"${LOCK_FILE}" || fail "cannot open lock file" 4
flock -x -w 30 9 || fail "could not acquire lock within 30s" 4

tmp_out="$(mktemp -p /dev/shm ichor-secrets.XXXXXX)"
trap 'rm -f "${tmp_out}"' EXIT

umask 077
: >"${tmp_out}"

shopt -s nullglob
count=0
for f in "${SECRETS_DIR}"/*.env; do
  base="$(basename "$f")"
  case "${base}" in
    *.example) continue ;;
  esac

  # Detect SOPS encryption marker. SOPS YAML/JSON uses a top-level `sops:`
  # key; SOPS *dotenv* output (the format infra/secrets/*.env are stored in)
  # flattens metadata to `sops_version=` / `sops_age__list_*=` lines and has
  # NO `sops:` line. Detect either form — the original `^sops:`-only check
  # silently skipped every dotenv-encrypted file (r86 RUNBOOK-020 finding:
  # produced an empty bundle + exit 0, the worst kind of silent failure).
  if ! grep -qE '^sops:|^sops_version=' "$f" 2>/dev/null; then
    log "skip ${base} (not SOPS-encrypted)"
    continue
  fi

  log "decrypt ${base}"
  if ! sops --decrypt --output-type dotenv "$f" >>"${tmp_out}" 2>/dev/null; then
    fail "decrypt failed: ${base}" 3
  fi
  printf '\n' >>"${tmp_out}"
  count=$((count + 1))
done
shopt -u nullglob

[ "${count}" -gt 0 ] || log "warning: zero encrypted secrets decrypted"

# Atomic move into final tmpfs path, 0600 ichor:ichor.
chmod 0600 "${tmp_out}"
if id -u ichor >/dev/null 2>&1; then
  chown ichor:ichor "${tmp_out}" 2>/dev/null || true
fi
mv -f "${tmp_out}" "${OUT_FILE}"
trap - EXIT

log "wrote ${count} secret bundle(s) to ${OUT_FILE}"
