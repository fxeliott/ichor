{
  "name": "ichor",
  "version": "0.0.0",
  "private": true,
  "description": "Ichor — autonomous market intelligence platform (Phase 0)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "2.9.7",
    "typescript": "5.9.3",
    "prettier": "3.8.3",
    "eslint": "10.3.0",
    "@types/node": "22.19.17"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "postcss": ">=8.5.10"
    }
  }
}
