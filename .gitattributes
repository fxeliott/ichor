# Auto-detect text files and normalize line endings to LF (Linux convention)
* text=auto eol=lf

# Force LF for shell scripts and YAML (would break otherwise on Linux)
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf

# Force CRLF for Windows-only scripts
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.parquet binary
*.h5 binary
*.pkl binary
*.joblib binary
